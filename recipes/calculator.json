{
  "title": "中国 2025 综合所得个税快算",
  "subtitle": "cells + JS operator modules demo",
  "author": "llm-report-html",
  "date": "2026-05-10",

  "runtime": {
    "operators": [
      "./runtime/taxableIncome.mjs",
      "./runtime/tax2025.mjs",
      "./runtime/afterTax.mjs",
      "./runtime/effectiveRate.mjs"
    ]
  },

  "cells": {
    "income": {
      "kind": "input",
      "type": "number",
      "default": 360000,
      "min": 0,
      "max": 99999999,
      "step": 10000,
      "label": "年综合所得（含工资 / 奖金 / 劳务等，元）"
    },
    "deduction": {
      "kind": "input",
      "type": "number",
      "default": 60000,
      "min": 0,
      "step": 1000,
      "label": "起征点 + 专项附加扣除合计（元）"
    },
    "taxable": {
      "kind": "computed",
      "type": "number",
      "expr": {
        "call": "taxableIncome",
        "args": [
          { "cell": "income" },
          { "cell": "deduction" }
        ]
      }
    },
    "tax": {
      "kind": "computed",
      "type": "number",
      "expr": {
        "call": "tax2025",
        "args": [
          { "cell": "taxable" }
        ]
      }
    },
    "after_tax": {
      "kind": "computed",
      "type": "number",
      "expr": {
        "call": "afterTax",
        "args": [
          { "cell": "income" },
          { "cell": "tax" }
        ]
      }
    },
    "effective_rate": {
      "kind": "computed",
      "type": "number",
      "expr": {
        "call": "effectiveRate",
        "args": [
          { "cell": "income" },
          { "cell": "tax" }
        ]
      }
    }
  },

  "sections": [
    {
      "type": "callout",
      "kind": "info",
      "text": "调下方两个数字看 stat 卡片实时变。JSON 只声明 cell 图；税法计算由相邻 JS operator module 持有 contract、实现和测试。"
    },

    { "type": "heading", "level": 2, "text": "输入" },
    { "type": "input", "bind": "income" },
    { "type": "input", "bind": "deduction" },

    { "type": "heading", "level": 2, "text": "计算结果" },
    {
      "type": "columns",
      "items": [
        {
          "sections": [
            { "type": "stat", "label": "应纳税所得额", "value": { "$bind": "taxable" }, "format": "currency" }
          ]
        },
        {
          "sections": [
            { "type": "stat", "label": "应缴个税", "value": { "$bind": "tax" }, "format": "currency" }
          ]
        },
        {
          "sections": [
            { "type": "stat", "label": "税后收入", "value": { "$bind": "after_tax" }, "format": "currency" }
          ]
        }
      ]
    },
    { "type": "stat", "label": "实际税率（综合）", "value": { "$bind": "effective_rate" }, "format": "percent" },

    {
      "type": "details",
      "summary": "2025 综合所得年度税率表（点开看分段）",
      "sections": [
        {
          "type": "table",
          "columns": ["级数", "应纳税所得额（元）", "税率", "速算扣除数"],
          "rows": [
            ["1", "≤ 36,000", "3%", "0"],
            ["2", "36,000 ~ 144,000", "10%", "2,520"],
            ["3", "144,000 ~ 300,000", "20%", "16,920"],
            ["4", "300,000 ~ 420,000", "25%", "31,920"],
            ["5", "420,000 ~ 660,000", "30%", "52,920"],
            ["6", "660,000 ~ 960,000", "35%", "85,920"],
            ["7", "960,000 以上", "45%", "181,920"]
          ]
        }
      ]
    },

    {
      "type": "aside",
      "title": "原理速记",
      "sections": [
        {
          "type": "paragraph",
          "text": "输入控件 → `cells.<name>` input → typed expr 依赖图 → JS operator module → stat 订阅绑定值。复杂业务逻辑不进入 JSON。"
        }
      ]
    }
  ]
}
