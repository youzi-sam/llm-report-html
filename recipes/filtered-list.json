{
  "title": "<演示：可筛选的 N+1 列表>",
  "subtitle": "array binding + section.if + JS operator modules demo",

  "runtime": {
    "operators": [
      "./runtime/passingCandidates.mjs",
      "./runtime/passingCount.mjs"
    ]
  },

  "cells": {
    "min_score": {
      "kind": "input",
      "type": "number",
      "default": 70,
      "min": 0,
      "max": 100,
      "step": 5,
      "label": "分数下限"
    },
    "show_summary": {
      "kind": "input",
      "type": "boolean",
      "default": true,
      "label": "显示摘要"
    },
    "candidates": {
      "kind": "computed",
      "type": "array",
      "expr": {
        "call": "passingCandidates",
        "args": [
          { "cell": "min_score" }
        ]
      }
    },
    "passing_count": {
      "kind": "computed",
      "type": "number",
      "expr": {
        "call": "passingCount",
        "args": [
          { "cell": "min_score" }
        ]
      }
    }
  },

  "sections": [
    {
      "type": "callout",
      "kind": "info",
      "text": "调下方滑块 → 列表实时过滤；勾选/取消 → 摘要 callout 整块出现/消失。名单计算在 JS operator module 中。"
    },

    { "type": "input", "bind": "min_score" },
    { "type": "input", "bind": "show_summary" },

    {
      "type": "callout",
      "kind": "success",
      "title": "通过人数",
      "text": "**{$bind:passing_count}** 人达到 {$bind:min_score} 分以上",
      "if": { "$bind": "show_summary" }
    },

    { "type": "heading", "level": 2, "text": "通过名单" },
    { "type": "list", "ordered": true, "items": { "$bind": "candidates" } },

    {
      "type": "aside",
      "title": "静态边界",
      "if": { "$bind": "show_summary" },
      "sections": [
        {
          "type": "paragraph",
          "text": "渲染产物仍然是自包含 HTML；operator module 在 render 阶段经过 contract/test 校验后内联进页面。"
        }
      ]
    }
  ]
}
