{
  "kind": "encoding",
  "binds": "timeline",
  "fields": [
    "items"
  ],
  "usage": "时间线大事记，items 是 {date,text}[]",
  "schema": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "items"
    ],
    "properties": {
      "items": {
        "anyOf": [
          {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "date",
                "text"
              ],
              "properties": {
                "date": {
                  "type": "string"
                },
                "text": {
                  "type": "string"
                }
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "$bind"
            ],
            "properties": {
              "$bind": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        ]
      },
      "if": {
        "anyOf": [
          {
            "type": "boolean"
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "$bind"
            ],
            "properties": {
              "$bind": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        ]
      }
    }
  },
  "examples": [
    {
      "items": [
        {
          "date": "2009",
          "text": "Cloudflare 创立"
        },
        {
          "date": "2017",
          "text": "Workers 发布"
        }
      ]
    }
  ]
}
