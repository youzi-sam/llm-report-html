{
  "kind": "layout",
  "binds": "columns",
  "fields": [
    "items"
  ],
  "usage": "N 列并排（最多 4 列）",
  "schema": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "items"
    ],
    "properties": {
      "items": {
        "type": "array",
        "minItems": 1,
        "maxItems": 4,
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "sections"
          ],
          "properties": {
            "sections": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/section"
              }
            }
          }
        }
      },
      "if": {
        "anyOf": [
          {
            "type": "boolean"
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "$bind"
            ],
            "properties": {
              "$bind": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        ]
      }
    }
  },
  "examples": [
    {
      "items": [
        {
          "sections": [
            {
              "type": "callout",
              "kind": "success",
              "text": "**优势**"
            }
          ]
        },
        {
          "sections": [
            {
              "type": "callout",
              "kind": "warn",
              "text": "**挑战**"
            }
          ]
        }
      ]
    }
  ]
}
