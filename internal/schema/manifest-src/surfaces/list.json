{
  "kind": "encoding",
  "binds": "list",
  "fields": [
    "ordered",
    "items"
  ],
  "usage": "项目符号 / 编号列表，items 可嵌套",
  "schema": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "items"
    ],
    "properties": {
      "ordered": {
        "anyOf": [
          {
            "type": "boolean"
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "$bind"
            ],
            "properties": {
              "$bind": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        ]
      },
      "items": {
        "anyOf": [
          {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/list.item"
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "$bind"
            ],
            "properties": {
              "$bind": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        ]
      },
      "if": {
        "anyOf": [
          {
            "type": "boolean"
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "$bind"
            ],
            "properties": {
              "$bind": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        ]
      }
    }
  },
  "examples": [
    {
      "ordered": false,
      "items": [
        "第一项",
        "第二项",
        {
          "text": "嵌套项",
          "children": [
            "子 A",
            "子 B"
          ]
        }
      ]
    }
  ]
}
