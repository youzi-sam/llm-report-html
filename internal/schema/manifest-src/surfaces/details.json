{
  "kind": "layout",
  "binds": "accordion",
  "fields": [
    "summary",
    "open",
    "sections"
  ],
  "usage": "可折叠块（accordion）",
  "schema": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "summary",
      "sections"
    ],
    "properties": {
      "summary": {
        "type": "string"
      },
      "open": {
        "anyOf": [
          {
            "type": "boolean"
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "$bind"
            ],
            "properties": {
              "$bind": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        ]
      },
      "sections": {
        "type": "array",
        "minItems": 1,
        "items": {
          "$ref": "#/$defs/section"
        }
      },
      "if": {
        "anyOf": [
          {
            "type": "boolean"
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "$bind"
            ],
            "properties": {
              "$bind": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        ]
      }
    }
  },
  "examples": [
    {
      "summary": "技术细节（点开看）",
      "sections": [
        {
          "type": "paragraph",
          "text": "深入解释..."
        }
      ]
    }
  ]
}
