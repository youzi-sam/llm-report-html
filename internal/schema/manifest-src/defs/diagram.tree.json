              {
                "label": "Next.js"
              },
              {
                "label": "Remix"
              }
            ]
          },
          {
            "label": "Vue 系",
            "children": [
              {
                "label": "Nuxt"
              }
            ]
          }
        ]
      }
    }
  ]
}
